rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // === Helper ===
    function isSignedIn() { return request.auth != null; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }
    function isAdmin() {
      // L'utente è admin se la sua email è elencata in un doc speciale "admins/list"
      return isSignedIn() && request.auth.token.email != null
             && exists(/databases/$(database)/documents/admins/list)
             && get(/databases/$(database)/documents/admins/list).data.emails.hasAny([request.auth.token.email]);
    }

    // === Profili utente ===
    match /users/{uid} {
      // Lettura pubblica (per classifica) per tutti gli utenti autenticati;
      // scrittura solo al proprietario o all'admin
      allow read: if isSignedIn();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid);
      allow delete: if isAdmin();

      // Subcollections: collezione, mappa — solo owner/admin
      match /{sub=**} {
        allow read, write: if isOwner(uid) || isAdmin();
      }
    }

    // === Configurazione di gioco (range stat, ecc.) — lettura pubblica, scrittura admin ===
    match /config/{doc} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    // negozio_settings coperto dalla regola /config/{doc} sopra

    // === Cataloghi (lettura pubblica, scrittura solo admin) ===
    match /catalogo_waifu/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /catalogo_outfit/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /catalogo_pose/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /catalogo_mosse/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /drops/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // === Lista admin (lettura pubblica per check, scrittura solo da console Firebase) ===
    match /admins/{doc} {
      allow read: if isSignedIn();
      allow write: if false; // gestito solo dalla console Firebase
    }

    // === Partite multiplayer ===
    match /partite_multi/{codice} {
      // Lettura: qualsiasi utente autenticato (serve per unirsi e per il listener)
      allow read: if isSignedIn();

      // Creazione: qualsiasi utente autenticato, purché si metta come creatore
      allow create: if isSignedIn()
                    && request.resource.data.creatore == request.auth.uid;

      // Aggiornamento: il creatore, giocatori già presenti, o un nuovo giocatore
      // che si sta aggiungendo (lobby aperta, non ancora iniziata)
      allow update: if isSignedIn()
                    && (
                      resource.data.creatore == request.auth.uid
                      || resource.data.giocatori.keys().hasAny([request.auth.uid])
                      || resource.data.stato == 'lobby'
                    );

      // Eliminazione: solo il creatore o admin
      allow delete: if isSignedIn()
                    && (resource.data.creatore == request.auth.uid || isAdmin());
    }

    // === Amicizie ===
    match /friendships/{docId} {
      // Solo i due diretti interessati possono leggere
      allow read: if isSignedIn()
                  && (resource.data.fromUid == request.auth.uid
                      || resource.data.toUid == request.auth.uid);
      // Creazione: solo il mittente può creare (fromUid = proprio uid)
      allow create: if isSignedIn()
                    && request.resource.data.fromUid == request.auth.uid;
      // Aggiornamento: solo il destinatario può accettare
      allow update: if isSignedIn()
                    && resource.data.toUid == request.auth.uid;
      // Eliminazione: uno dei due può rimuovere l'amicizia
      allow delete: if isSignedIn()
                    && (resource.data.fromUid == request.auth.uid
                        || resource.data.toUid == request.auth.uid);
    }

    // === Pack Snapshots ===
    match /pack_snapshots/{snapshotId} {
      allow read: if isSignedIn();
      // Il client può creare la propria snapshot (ownerUid deve corrispondere al proprio uid)
      allow create: if isSignedIn()
                    && request.resource.data.ownerUid == request.auth.uid;
      allow update, delete: if false;
    }

    // === Fishing Attempts (read-only lato client) ===
    match /fishing_attempts/{attemptId} {
      allow read: if isSignedIn()
                  && resource.data.fisherUid == request.auth.uid;
      allow write: if false;
    }

    // === Trade Requests ===
    match /trade_requests/{tradeId} {
      // Solo i due diretti interessati possono leggere
      allow read: if isSignedIn()
                  && (resource.data.fromUid == request.auth.uid
                      || resource.data.toUid == request.auth.uid);
      // Scrittura solo da server (Admin SDK bypassa le rules)
      allow write: if false;
    }

    // === Mappa Pixel — chunk (lettura pubblica, scrittura solo server Admin SDK) ===
    match /map_chunks/{chunkId} {
      allow read: if isSignedIn();
      allow write: if false; // solo Admin SDK lato server
    }

    // === Battaglie territoriali — solo attaccante/difensore può leggere ===
    match /territory_battles/{battleId} {
      allow read: if isSignedIn()
                  && (resource.data.attackerUid == request.auth.uid
                      || resource.data.defenderUid == request.auth.uid);
      allow create: if isSignedIn()
                    && request.resource.data.attackerUid == request.auth.uid;
      allow update: if isSignedIn()
                    && resource.data.attackerUid == request.auth.uid;
      allow delete: if false;
    }

    // === Voti Swap — ogni utente scrive solo i propri voti ===
    match /swap_votes/{voteId} {
      allow read: if isAdmin();
      allow create, update: if isSignedIn()
                            && request.resource.data.uid == request.auth.uid;
      allow delete: if false;
    }

    // === Configurazione Swap (reward, pausa) — lettura pubblica, scrittura admin ===
    match /swap_config/{doc} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // === Storico classifiche settimanali waifu — lettura pubblica, scrittura server ===
    match /waifu_weekly_results/{weekId} {
      allow read: if isSignedIn();
      allow write: if false; // solo Admin SDK
    }

    // === Offerte acquisto pixel — solo i due interessati ===
    match /pixel_offers/{offerId} {
      allow read: if isSignedIn()
                  && (resource.data.fromUid == request.auth.uid
                      || resource.data.toUid == request.auth.uid);
      allow create: if isSignedIn()
                    && request.resource.data.fromUid == request.auth.uid;
      allow update: if isSignedIn()
                    && resource.data.toUid == request.auth.uid;
      allow delete: if false;
    }

    // === Log operazioni admin (chiusura classifica ecc.) ===
    match /admin_logs/{logId} {
      allow read: if isAdmin();
      allow write: if false; // solo Admin SDK lato server
    }

    // Default: nega tutto
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
