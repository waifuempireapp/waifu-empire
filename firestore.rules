rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // === Helper ===
    function isSignedIn() { return request.auth != null; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }
    function isAdmin() {
      // L'utente è admin se la sua email è elencata in un doc speciale "admins/list"
      return isSignedIn() && request.auth.token.email != null
             && exists(/databases/$(database)/documents/admins/list)
             && get(/databases/$(database)/documents/admins/list).data.emails.hasAny([request.auth.token.email]);
    }

    // === Profili utente ===
    match /users/{uid} {
      // Lettura pubblica (per classifica) per tutti gli utenti autenticati;
      // scrittura solo al proprietario o all'admin
      allow read: if isSignedIn();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid);
      allow delete: if isAdmin();

      // Subcollections: collezione, mappa — solo owner/admin
      match /{sub=**} {
        allow read, write: if isOwner(uid) || isAdmin();
      }
    }

    // === Configurazione di gioco (range stat, ecc.) — lettura pubblica, scrittura admin ===
    match /config/{doc} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // === Cataloghi (lettura pubblica, scrittura solo admin) ===
    match /catalogo_waifu/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /catalogo_outfit/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /catalogo_pose/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /drops/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // === Lista admin (lettura pubblica per check, scrittura solo da console Firebase) ===
    match /admins/{doc} {
      allow read: if isSignedIn();
      allow write: if false; // gestito solo dalla console Firebase
    }

    // === Partite multiplayer ===
    match /partite_multi/{codice} {
      // Lettura: qualsiasi utente autenticato (serve per unirsi e per il listener)
      allow read: if isSignedIn();

      // Creazione: qualsiasi utente autenticato, purché si metta come creatore
      allow create: if isSignedIn()
                    && request.resource.data.creatore == request.auth.uid;

      // Aggiornamento: solo giocatori già presenti nella partita o il creatore
      allow update: if isSignedIn()
                    && (
                      resource.data.creatore == request.auth.uid
                      || resource.data.giocatori.keys().hasAny([request.auth.uid])
                    );

      // Eliminazione: solo il creatore o admin
      allow delete: if isSignedIn()
                    && (resource.data.creatore == request.auth.uid || isAdmin());
    }

    // Default: nega tutto
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
