# Firebase Web Config (lato client — sicure da esporre)
# In Nuxt 3 si usano NUXT_PUBLIC_* invece di NEXT_PUBLIC_*
NUXT_PUBLIC_FIREBASE_API_KEY=your-api-key
NUXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NUXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NUXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NUXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000
NUXT_PUBLIC_FIREBASE_APP_ID=1:000:web:000

# Firebase Admin SDK (lato server — SEGRETE, mai nel client)
FIREBASE_ADMIN_PROJECT_ID=your-project-id
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nABC...\n-----END PRIVATE KEY-----\n"

# Cloudinary (upload immagini — SEGRETE)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ImageKit (CDN immagini)
NUXT_PUBLIC_IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_id
IMAGEKIT_PRIVATE_KEY=your_imagekit_private_key

# Email amministratori (separate da virgola)
ADMIN_EMAILS=tua-email@gmail.com

# PayPal (SEGRETE lato server)
PAYPAL_BASE_URL=https://api-m.sandbox.paypal.com
PAYPAL_CLIENT_ID=your-sandbox-client-id
PAYPAL_CLIENT_SECRET=your-sandbox-client-secret

# PayPal Client ID pubblico — usato dal JS SDK nel browser
NUXT_PUBLIC_PAYPAL_CLIENT_ID=your-sandbox-client-id
